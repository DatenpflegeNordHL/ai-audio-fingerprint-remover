{
  "version_target": "0.14.0",
  "status": "implemented_private_dashboard_artifact_rendering",
  "deep_search_decision": "not_needed_internal_repo_only",
  "deep_search_completed": false,
  "approved_backend_stack": [
    "FastAPI",
    "Uvicorn",
    "python-multipart"
  ],
  "approved_dependencies": {
    "web": [
      "fastapi>=0.138.1,<0.139.0",
      "uvicorn>=0.49.0,<0.50.0",
      "python-multipart>=0.0.32,<0.0.33"
    ],
    "test": []
  },
  "license_concerns": "No license concern was found in the supplied Deep Search summary for the approved direct backend and test dependency direction.",
  "auth": {
    "type": "bearer_token",
    "env_var": "AQH_WEB_TOKEN",
    "required_for_api_endpoints": true,
    "health_requires_auth": false,
    "constant_time_compare": true
  },
  "max_upload_mib": 100,
  "job_storage": {
    "env_var": "AQH_WEB_JOB_ROOT",
    "default_root": ".var/private-web/jobs",
    "per_job_directories": [
      "input",
      "artifacts",
      "status.json"
    ],
    "random_job_ids": true,
    "user_filenames_as_paths": false
  },
  "cleanup": {
    "job_ttl_hours_env": "AQH_JOB_TTL_HOURS",
    "job_ttl_hours_default": 24,
    "partial_ttl_minutes_env": "AQH_PARTIAL_TTL_MINUTES",
    "partial_ttl_minutes_default": 60
  },
  "endpoints": [
    "GET /health",
    "GET /",
    "POST /api/jobs",
    "GET /api/jobs/{job_id}",
    "GET /api/jobs/{job_id}/artifacts/{artifact_name}",
    "DELETE /api/jobs/{job_id}",
    "POST /api/maintenance/cleanup"
  ],
  "supported_modes": [
    "analyze",
    "release-check",
    "inspect-metadata",
    "visualize"
  ],
  "deferred_modes": [
    "clean-metadata",
    "visualize-compare",
    "compare",
    "humanize"
  ],
  "processing_execution": "synchronous_safe_single_file_modes",
  "generated_artifacts": {
    "analyze": "analysis.json",
    "release-check": "release_check.json",
    "inspect-metadata": "metadata.json",
    "visualize": "visualization.json"
  },
  "operator_page": {
    "path": "/",
    "plain_html": true,
    "inline_css": true,
    "vanilla_javascript": true,
    "external_assets": false,
    "token_persistence": false,
    "artifact_rendering": true,
    "metric_cards_from_artifacts": true,
    "waveform_preview_from_visualization_json": true,
    "spectrogram_preview_from_visualization_json": true,
    "metadata_panel_from_metadata_display": true,
    "fake_metrics": false
  },
  "metadata_display": {
    "sanitized_embedded_images": true,
    "preserves_detected_metadata_keys": true,
    "max_display_chars": 500,
    "modifies_uploaded_file": false
  },
  "security_requirements": [
    "private beta only",
    "bearer-token auth for API endpoints",
    "one uploaded file per request",
    "allowlisted audio extensions",
    "enforce byte count while copying uploads",
    "advisory content type only",
    "basic magic-byte sanity checks",
    "random job IDs",
    "path traversal protection",
    "temporary job storage",
    "automatic cleanup helper"
  ],
  "safety_boundary": [
    "technical job-status responses only",
    "temporary uploads only",
    "no committed uploaded audio or generated outputs",
    "no fake dashboard metrics",
    "no platform or distributor guarantees",
    "no watermark, fingerprint, provenance, C2PA, source-attribution, detector, evasion, detectability, platform-certification, or distributor-guarantee outcomes"
  ],
  "not_approved": [
    "frontend UI",
    "frontend framework",
    "React",
    "Vite",
    "Next",
    "wavesurfer.js",
    "Meyda",
    "three.js",
    "audioMotion-analyzer",
    "deployment",
    "DNS config",
    "public launch",
    "final legal or privacy public text",
    "accounts",
    "OAuth",
    "database",
    "Redis",
    "Celery",
    "billing",
    "analytics",
    "multi-tenant storage",
    "audio processing behavior changes",
    "file-modifying web modes",
    "two-file web modes",
    "output-audio web modes"
  ],
  "project_reborn_boundary": {
    "reference_only": true,
    "copied": false,
    "imported": false,
    "executed": false,
    "packaged": false,
    "exposed": false
  }
}
