{
  "version_target": "0.16.0",
  "status": "implemented_local_security_retention_and_operator_hardening",
  "deep_search_decision": "not_needed_internal_repo_only",
  "deep_search_completed": false,
  "approved_backend_stack": [
    "FastAPI",
    "Uvicorn",
    "python-multipart"
  ],
  "approved_dependencies": {
    "web": [
      "fastapi>=0.138.1,<0.139.0",
      "uvicorn>=0.49.0,<0.50.0",
      "python-multipart>=0.0.32,<0.0.33"
    ],
    "test": []
  },
  "license_concerns": "No license concern was found in the supplied Deep Search summary for the approved direct backend and test dependency direction.",
  "auth": {
    "type": "bearer_token",
    "env_var": "AQH_WEB_TOKEN",
    "required_for_api_endpoints": true,
    "health_requires_auth": false,
    "constant_time_compare": true
  },
  "max_upload_mib": 100,
  "job_storage": {
    "env_var": "AQH_WEB_JOB_ROOT",
    "default_root": ".var/private-web/jobs",
    "per_job_directories": [
      "input",
      "artifacts",
      "status.json"
    ],
    "random_job_ids": true,
    "user_filenames_as_paths": false
  },
  "cleanup": {
    "job_ttl_hours_env": "AQH_JOB_TTL_HOURS",
    "job_ttl_hours_default": 24,
    "partial_ttl_minutes_env": "AQH_PARTIAL_TTL_MINUTES",
    "partial_ttl_minutes_default": 60
  },
  "endpoints": [
    "GET /health",
    "GET /",
    "GET /api/config",
    "GET /api/jobs",
    "POST /api/jobs",
    "POST /api/compare-jobs",
    "GET /api/jobs/{job_id}",
    "GET /api/jobs/{job_id}/artifacts/{artifact_name}",
    "DELETE /api/jobs/{job_id}",
    "POST /api/maintenance/cleanup"
  ],
  "security_headers": {
    "x_content_type_options": "nosniff",
    "referrer_policy": "no-referrer",
    "x_frame_options": "DENY",
    "api_cache_control": "no-store"
  },
  "supported_modes": [
    "analyze",
    "release-check",
    "inspect-metadata",
    "clean-metadata",
    "visualize",
    "compare",
    "visualize-compare"
  ],
  "single_file_modes": [
    "analyze",
    "release-check",
    "inspect-metadata",
    "clean-metadata",
    "visualize"
  ],
  "two_file_modes": [
    "compare",
    "visualize-compare"
  ],
  "deferred_modes": [
    "humanize"
  ],
  "processing_execution": "synchronous_safe_single_and_two_file_modes",
  "generated_artifacts": {
    "analyze": "analysis.json",
    "release-check": "release_check.json",
    "inspect-metadata": "metadata.json",
    "clean-metadata": [
      "cleaned_output.<ext>",
      "metadata_before.json",
      "clean_metadata.json",
      "metadata_after.json"
    ],
    "visualize": "visualization.json",
    "compare": "compare.json",
    "visualize-compare": [
      "compare.json",
      "visual_compare.json"
    ]
  },
  "operator_page": {
    "path": "/",
    "plain_html": true,
    "inline_css": true,
    "vanilla_javascript": true,
    "external_assets": false,
    "token_persistence": false,
    "artifact_rendering": true,
    "metric_cards_from_artifacts": true,
    "waveform_preview_from_visualization_json": true,
    "spectrogram_preview_from_visualization_json": true,
    "metadata_panel_from_metadata_display": true,
    "single_file_and_two_file_modes": true,
    "local_exposure_warning": true,
    "cleanup_control": true,
    "retention_display": true,
    "recent_jobs_display": true,
    "fake_metrics": false
  },
  "operator_config_endpoint": {
    "path": "GET /api/config",
    "requires_auth": true,
    "exposes_paths": false,
    "exposes_secrets": false
  },
  "job_listing_endpoint": {
    "path": "GET /api/jobs",
    "requires_auth": true,
    "recent_summaries_only": true,
    "exposes_paths": false
  },
  "artifact_downloads": {
    "allowlisted_names": true,
    "must_be_listed_in_status_json": true,
    "path_traversal_protected": true
  },
  "metadata_display": {
    "sanitized_embedded_images": true,
    "preserves_detected_metadata_keys": true,
    "max_display_chars": 500,
    "modifies_uploaded_file": false
  },
  "clean_metadata_web": {
    "writes_cleaned_copy_to_artifacts": true,
    "overwrites_uploaded_input": false,
    "before_after_metadata_artifacts": true
  },
  "two_file_workflows": {
    "fixed_upload_fields": [
      "before_file",
      "after_file"
    ],
    "fixed_storage_paths": [
      "input/before.<ext>",
      "input/after.<ext>"
    ],
    "user_filenames_as_paths": false
  },
  "security_requirements": [
    "private beta only",
    "bearer-token auth for API endpoints",
    "one uploaded file for single-file requests",
    "fixed before and after uploaded files for two-file requests",
    "allowlisted audio extensions",
    "enforce byte count while copying uploads",
    "advisory content type only",
    "basic magic-byte sanity checks",
    "random job IDs",
    "path traversal protection",
    "temporary job storage",
    "automatic cleanup helper",
    "safe auth errors",
    "lightweight security headers",
    "status-listed artifact downloads"
  ],
  "safety_boundary": [
    "technical job-status responses only",
    "temporary uploads only",
    "no committed uploaded audio or generated outputs",
    "no fake dashboard metrics",
    "no platform or distributor guarantees",
    "no watermark, fingerprint, provenance, C2PA, source-attribution, detector, evasion, detectability, platform-certification, or distributor-guarantee outcomes"
  ],
  "not_approved": [
    "frontend framework",
    "React",
    "Vite",
    "Next",
    "wavesurfer.js",
    "Meyda",
    "three.js",
    "audioMotion-analyzer",
    "deployment",
    "DNS config",
    "public launch",
    "final legal or privacy public text",
    "accounts",
    "OAuth",
    "database",
    "Redis",
    "Celery",
    "billing",
    "analytics",
    "multi-tenant storage",
    "audio processing behavior changes",
    "humanize web mode",
    "other output-audio web modes"
  ],
  "project_reborn_boundary": {
    "reference_only": true,
    "copied": false,
    "imported": false,
    "executed": false,
    "packaged": false,
    "exposed": false
  }
}
